# Required: LLM Provider (DeepSeek, OpenAI, or compatible)
API_KEY=your_api_key_here
BASE_URL=https://api.deepseek.com

# Optional: Model Selection
PLANNER_MODEL=deepseek-reasoner
EXECUTOR_MODEL=deepseek-coder

# Optional: Multi-Agent System
MULTI_AGENT_ENABLED=1

# Optional: Inngest Durable Workflow Runtime
INNGEST_APP_ID=caspercode
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_ENV=

# Optional: Development Settings
DEBUG=0
